{
  "name": "mzj-publisher-agent",
  "version": "1.3.0",
  "description": "MZJ local publishing agent with direct publish-now execution.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js",
    "dist": "electron-builder --win portable --x64",
    "pack": "electron-builder --dir",
    "dist:installer": "electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "firebase": "^10.12.5",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "electron": "^31.7.7"
  },
  "build": {
    "appId": "com.mzj.publisheragent",
    "productName": "MZJ Publisher Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "publisher-config.json",
      "renderer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "author": "MZJ Workspace"
}