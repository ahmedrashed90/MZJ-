{
  "name": "mzj-publisher-agent",
  "version": "1.0.0",
  "description": "MZJ local publishing agent for reading agenda folders and saving publishing jobs to Firebase.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js",
    "dist": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron": "^31.7.7",
    "firebase": "^10.12.5",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mzj.publisheragent",
    "productName": "MZJ Publisher Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "publisher-config.json",
      "renderer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}