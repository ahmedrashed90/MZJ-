rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /final-media/{fileName} {
      allow read, write: if true;
    }

    match /publish-prep/{userId}/{taskId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    match /local-publisher-media/{allPaths=**} {
      allow read, write, delete: if true;
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write, delete: if false;
    }
  }
}
